{
  "name": "brillianda",
  "version": "1.0.0",
  "private": true,
  "description": "Brillianda — Multi-tenant School Registry, LMS, and CBT Platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter db migrate",
    "db:generate": "pnpm --filter db generate",
    "db:seed": "pnpm --filter db seed",
    "db:studio": "pnpm --filter db studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
