# Root environment variables (copy to apps/api/.env and apps/web/.env.local)

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/brillianda

# JWT
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRES_IN=7d

# CORS / API
ALLOWED_ORIGINS=http://localhost:3000,https://*.brillianda.com
PORT=4000
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_BASE_DOMAIN=brillianda.com
