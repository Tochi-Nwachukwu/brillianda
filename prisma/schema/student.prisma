model Student {
  id               String   @id @default(uuid()) @db.Uuid
  schoolId         String   @db.Uuid
  school           School   @relation(fields: [schoolId], references: [id])
  
  // Basic Info
  firstName        String
  lastName         String
  middleName       String?
  email            String?  // Optional for younger students
  password         String   // Hashed
  gender           Gender
  dateOfBirth      DateTime
  profilePicture   String?  // URL to S3
  
  // School Specifics
  admissionNumber  String
  admissionDate    DateTime @default(now())
  classId          String   @db.Uuid
  currentClass     Class    @relation(fields: [classId], references: [id])
  
  // Many-to-Many or One-to-Many with Parents
  parents          Parent[] 
  
  // Nigerian School Context Extras
  house            String?  // e.g., "Blue House", "Loyola"
  bloodGroup       String?  // Useful for school clinics
  genotype         String?
  
  // System State
  isActive         Boolean  @default(true)
  status           StudentStatus @default(PROSPECT) // PROSPECT, ACTIVE, GRADUATED, WITHDRAWN

  // Results & CBT Relations
  submissions      CbtSubmission[]
  grades           Grade[]

  @@unique([schoolId, admissionNumber]) // CRITICAL: Prevent duplicate IDs within the same school
  @@index([schoolId, classId])           // Performance for class lists
}

enum Gender {
  MALE
  FEMALE
}

enum StudentStatus {
  PROSPECT
  ACTIVE
  GRADUATED
  WITHDRAWN
  SUSPENDED
}